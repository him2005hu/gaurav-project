rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Config matches
    match /configs/{configId} {
      allow read: if true; // Publicly readable
      allow write: if request.auth != null && isValidId(configId);
    }

    // Allow reading of test connection document
    match /test/{testId} {
      allow read: if true;
    }

    // Admin document match
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false; // Only manageable server-side
    }

    // Reusable, hardened helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
  }
}
